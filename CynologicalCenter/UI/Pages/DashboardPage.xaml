<Page x:Class="CynologicalCenter.UI.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Головна"
      Background="{StaticResource BackgroundBrush}"
      Loaded="Page_Loaded">

    <Grid>
        <Rectangle Fill="{StaticResource PawPatternBrush}"
                   IsHitTestVisible="False"/>

        <ScrollViewer Padding="28">
            <StackPanel>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtGreeting"
                                   Style="{StaticResource PageTitle}"
                                   Margin="0"/>
                        <TextBlock x:Name="TxtDate" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Style="{StaticResource Card}"
                            Padding="20,12" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtClock"
                                       FontSize="32" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <UniformGrid Columns="4" Margin="0,0,0,20">

                    <Border Style="{StaticResource Card}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock x:Name="TxtActiveClients"
                                       FontSize="30" FontWeight="Bold"
                                       Foreground="{StaticResource SecondaryActionBrush}"/>
                            <TextBlock Text="Активних клієнтів"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock x:Name="TxtTodaySessions"
                                       FontSize="30" FontWeight="Bold"
                                       Foreground="{StaticResource SecondaryActionBrush}"/>
                            <TextBlock Text="Занять сьогодні"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="VaccCard"
                            Style="{StaticResource Card}"
                            Margin="0,0,12,0"
                            Cursor="Hand"
                            MouseLeftButtonUp="VaccCard_Click">
                        <StackPanel>
                            <TextBlock x:Name="TxtExpiredVacc"
                                       FontSize="30" FontWeight="Bold"
                                       Foreground="{StaticResource SecondaryActionBrush}"/>
                            <TextBlock x:Name="TxtVaccLabel"
                                       Text="Прострочена вакцинація"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtVaccHint"
                                       Text="Натисніть для перегляду →"
                                       FontSize="10"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,4,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock x:Name="TxtTrainersCount"
                                       FontSize="30" FontWeight="Bold"
                                       Foreground="{StaticResource SecondaryActionBrush}"/>
                            <TextBlock Text="Активних тренерів"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Заняття сьогодні"
                                       Style="{StaticResource SectionTitle}"
                                       Margin="0"/>
                            <Border x:Name="TodayBadge"
                                    Background="#E8F0EE"
                                    CornerRadius="20"
                                    Padding="10,3"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTodayBadge"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           FontSize="12" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <Border x:Name="EmptySchedule"
                                Background="#F4F4EA"
                                CornerRadius="10" Padding="24"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="День вільний!"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                                <TextBlock Text="Запланованих занять на сьогодні немає"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="GridSchedule"
                                  Style="{StaticResource ModernDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Час"
                                                    Binding="{Binding SessionTime}"
                                                    Width="100"/>
                                <DataGridTextColumn Header="Собака"
                                                    Binding="{Binding Dog}" 
                                                    Width="130"/>
                                <DataGridTextColumn Header="Порода"
                                                    Binding="{Binding Breed}" 
                                                    Width="140"/>
                                <DataGridTextColumn Header="Тренер"
                                                    Binding="{Binding Trainer}"
                                                    Width="160"/>
                                <DataGridTextColumn Header="Курс"
                                                    Binding="{Binding Course}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Тривалість"
                                                    Binding="{Binding DurationMinutes, StringFormat={}{0} хв}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>