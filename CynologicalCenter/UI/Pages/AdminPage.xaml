<Page x:Class="CynologicalCenter.UI.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Адмін"
      Background="{StaticResource BackgroundBrush}"
      Loaded="Page_Loaded">

    <Grid>
        <Rectangle Fill="{StaticResource PawPatternBrush}"
                   IsHitTestVisible="False"/>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        Margin="0,0,0,20">
                <TextBlock Text="Журнал аудиту"
                           Style="{StaticResource PageTitle}"
                           Margin="0"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Margin="0,0,0,16" Padding="16">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Оновити"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnRefresh_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Card}"
                    Padding="0">
                <DataGrid x:Name="GridAudit"
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Час"
                                            Binding="{Binding ChangedAt, StringFormat=dd.MM.yyyy HH:mm:ss}"
                                            Width="150"/>
                        <DataGridTextColumn Header="Дія" Binding="{Binding Action}" Width="80"/>
                        <DataGridTextColumn Header="Таблиця" Binding="{Binding TableName}" Width="110"/>
                        <DataGridTextColumn Header="ID" Binding="{Binding RecordId}" Width="60"/>
                        <DataGridTextColumn Header="Користувач" Binding="{Binding ChangedBy}" Width="160"/>
                        <DataGridTextColumn Header="Джерело" Binding="{Binding OperationSource}" Width="90"/>
                        <DataGridTextColumn Header="Опис" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Page>