<Page x:Class="CynologicalCenter.UI.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Адмін"
      Loaded="Page_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Адміністрування"
                   FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,24"/>

        <StackPanel Grid.Row="1">

            <TextBlock Text="Журнал аудиту (останні записи)"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <DataGrid x:Name="GridAudit"
                      AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False"
                      Height="400"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Час"
                        Binding="{Binding ChangedAt,
                            StringFormat=dd.MM.yyyy HH:mm:ss}"
                        Width="150"/>
                    <DataGridTextColumn Header="Дія"
                        Binding="{Binding Action}" Width="80"/>
                    <DataGridTextColumn Header="Таблиця"
                        Binding="{Binding TableName}" Width="100"/>
                    <DataGridTextColumn Header="ID запису"
                        Binding="{Binding RecordId}" Width="80"/>
                    <DataGridTextColumn Header="Користувач"
                        Binding="{Binding ChangedBy}" Width="150"/>
                    <DataGridTextColumn Header="Джерело"
                        Binding="{Binding OperationSource}" Width="90"/>
                    <DataGridTextColumn Header="Опис"
                        Binding="{Binding Description}" Width="300"/>
                </DataGrid.Columns>
            </DataGrid>

            <Button Content="🔄 Оновити"
                    Height="32" Padding="16,0"
                    Background="#2563EB" Foreground="White"
                    BorderThickness="0"
                    HorizontalAlignment="Left"
                    Margin="0,12,0,0"
                    Click="BtnRefresh_Click"/>
        </StackPanel>
    </Grid>
</Page>