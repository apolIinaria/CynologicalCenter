<Page x:Class="CynologicalCenter.UI.Pages.OwnersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Клієнти"
      Loaded="Page_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Клієнти"
                   FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    Margin="0,0,0,12">
            <TextBox x:Name="TxtSearch"
                     Width="250" Height="32" Padding="8,4"
                     TextChanged="TxtSearch_TextChanged"/>
            <TextBlock Text="🔍" VerticalAlignment="Center"
                       Margin="8,0,16,0" FontSize="16"/>
            <Button Content="+ Додати клієнта"
                    Height="32" Padding="16,0"
                    Background="#2563EB" Foreground="White"
                    BorderThickness="0"
                    Click="BtnAdd_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="2" x:Name="GridOwners"
                  AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  SelectionChanged="GridOwners_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                    Binding="{Binding OwnerId}" Width="50"/>
                <DataGridTextColumn Header="ПІБ"
                    Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Телефон"
                    Binding="{Binding Phone}" Width="140"/>
                <DataGridTextColumn Header="Email"
                    Binding="{Binding Email}" Width="200"/>
                <DataGridTextColumn Header="Собак"
                    Binding="{Binding DogsCount}" Width="70"/>
                <DataGridTextColumn Header="Останній візит"
                    Binding="{Binding LastVisit,
                        StringFormat=dd.MM.yyyy}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    Margin="0,12,0,0">
            <Button x:Name="BtnEdit"
                    Content="✏ Редагувати"
                    Height="32" Padding="16,0" Margin="0,0,8,0"
                    Background="#0F172A" Foreground="White"
                    BorderThickness="0" IsEnabled="False"
                    Click="BtnEdit_Click"/>
            <Button x:Name="BtnDeactivate"
                    Content="🚫 Деактивувати"
                    Height="32" Padding="16,0"
                    Background="#DC2626" Foreground="White"
                    BorderThickness="0" IsEnabled="False"
                    Click="BtnDeactivate_Click"/>
        </StackPanel>

    </Grid>
</Page>