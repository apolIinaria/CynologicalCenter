<Page x:Class="CynologicalCenter.UI.Pages.TrainersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Тренери"
      Background="{StaticResource BackgroundBrush}"
      Loaded="Page_Loaded">

    <Grid>
        <Rectangle Fill="{StaticResource PawPatternBrush}"
                   IsHitTestVisible="False"/>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Тренери" Style="{StaticResource PageTitle}"/>

            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="16">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnAdd"
                            Content="Додати тренера"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"
                            Click="BtnAdd_Click"/>
                    <Button Content="Рейтинг KPI"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnKpi_Click"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2">
                <WrapPanel x:Name="WrapTrainers"
                           Orientation="Horizontal"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>