<Page x:Class="CynologicalCenter.UI.Pages.TrainersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Тренери"
      Loaded="Page_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Тренери"
                   FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="+ Додати тренера"
                    Height="32" Padding="16,0"
                    Background="#2563EB" Foreground="White"
                    BorderThickness="0"
                    Click="BtnAdd_Click"/>
            <Button Content="📈 KPI тренерів"
                    Height="32" Padding="16,0" Margin="8,0,0,0"
                    Background="#0369A1" Foreground="White"
                    BorderThickness="0"
                    Click="BtnKpi_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="2" x:Name="GridTrainers"
                  AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  SelectionChanged="GridTrainers_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                    Binding="{Binding TrainerId}" Width="50"/>
                <DataGridTextColumn Header="ПІБ"
                    Binding="{Binding FullName}" Width="180"/>
                <DataGridTextColumn Header="Телефон"
                    Binding="{Binding Phone}" Width="140"/>
                <DataGridTextColumn Header="Email"
                    Binding="{Binding Email}" Width="180"/>
                <DataGridTextColumn Header="Досвід (років)"
                    Binding="{Binding ExperienceYears}" Width="110"/>
                <DataGridTextColumn Header="Дата найму"
                    Binding="{Binding HireDate,
                        StringFormat=dd.MM.yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    Margin="0,12,0,0">
            <Button x:Name="BtnEdit"
                    Content="✏ Редагувати"
                    Height="32" Padding="16,0" Margin="0,0,8,0"
                    Background="#0F172A" Foreground="White"
                    BorderThickness="0" IsEnabled="False"
                    Click="BtnEdit_Click"/>
            <Button x:Name="BtnDelete"
                    Content="🗑 Видалити"
                    Height="32" Padding="16,0"
                    Background="#DC2626" Foreground="White"
                    BorderThickness="0" IsEnabled="False"
                    Click="BtnDelete_Click"/>
        </StackPanel>
    </Grid>
</Page>
