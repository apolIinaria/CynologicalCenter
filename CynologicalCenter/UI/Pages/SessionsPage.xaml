<Page x:Class="CynologicalCenter.UI.Pages.SessionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заняття"
      Background="{StaticResource BackgroundBrush}"
      Loaded="Page_Loaded">

    <Grid>
        <Rectangle Fill="{StaticResource PawPatternBrush}"
                   IsHitTestVisible="False"/>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Заняття"
                       Style="{StaticResource PageTitle}"/>

            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Margin="0,0,0,16" Padding="16">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnEnroll" 
                            Content="Записати на заняття"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,12,0"
                            Click="BtnEnroll_Click"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1.5" CornerRadius="8"
                            Background="White">
                        <ComboBox x:Name="CmbStatus"
                                  BorderThickness="0"
                                  Width="160" Height="36"
                                  Padding="8,0"
                                  Background="Transparent"
                                  SelectionChanged="CmbStatus_SelectionChanged"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <DataGrid x:Name="GridSessions"
                          Style="{StaticResource ModernDataGrid}" SelectionChanged="GridSessions_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата і час" Binding="{Binding SessionDatetime, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="Собака" Binding="{Binding DogNickname}" Width="130"/>
                        <DataGridTextColumn Header="Тренер" Binding="{Binding TrainerName}" Width="170"/>
                        <DataGridTextColumn Header="Курс" Binding="{Binding CourseName}" Width="180"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Оцінка" Binding="{Binding Grade}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3" Padding="0,12,0,0">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnComplete"
                            Content="Завершити"
                            Style="{StaticResource SuccessButton}"
                            IsEnabled="False" Margin="0,0,8,0"
                            Click="BtnComplete_Click"/>
                    <Button x:Name="BtnCancel"
                            Content="Скасувати"
                            Style="{StaticResource DangerButton}"
                            IsEnabled="False"
                            Click="BtnCancel_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>