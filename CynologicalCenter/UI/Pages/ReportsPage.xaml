<Page x:Class="CynologicalCenter.UI.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Звіти"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource PawPatternBrush}"
                   IsHitTestVisible="False"/>

        <ScrollViewer Padding="28">

            <StackPanel>
                <TextBlock Text="Звіти та аналітика"
                           Style="{StaticResource PageTitle}"/>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="AuditCard"
                            Grid.Row="0" Grid.Column="0"
                            Style="{StaticResource Card}"
                            Margin="0,0,12,12"
                            VerticalAlignment="Stretch">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Text="Журнал аудиту"
                                                   FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Аналіз операцій за період"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Від" Style="{StaticResource LabelText}"/>
                                        <DatePicker x:Name="DpAuditFrom"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="До" Style="{StaticResource LabelText}"/>
                                        <DatePicker x:Name="DpAuditTo"/>
                                    </StackPanel>
                                </Grid>

                            </StackPanel>

                            <Button Grid.Row="1"
                                    Content="Сформувати звіт"
                                    Style="{StaticResource ReportCardButton}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,12,0,0"
                                    Click="BtnAuditReport_Click"/>
                        </Grid>
                    </Border>

                    <Border x:Name="SecurityCard"
                            Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource Card}"
                            Margin="12,0,0,12"
                            VerticalAlignment="Stretch">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Text="Безпека"
                                                   FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Моніторинг інцидентів"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="Аналізувати останні (годин)"
                                           Style="{StaticResource LabelText}"/>

                                <TextBox x:Name="TxtHours"
                                         Text="24"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <Button Grid.Row="1"
                                    Content="Перевірити інциденти"
                                    Style="{StaticResource DangerButton}"
                                    Margin="0,12,0,0"
                                    Click="BtnSecurityReport_Click"/>
                        </Grid>
                    </Border>

                    <Border x:Name="ScheduleCard"
                            Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource Card}"
                            Margin="0,12,12,0"
                            VerticalAlignment="Stretch">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Text="Розклад тренера"
                                                   FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Заняття на обраний день"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="Тренер" Style="{StaticResource LabelText}"/>
                                <ComboBox x:Name="CmbTrainer" SelectedValuePath="TrainerId">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FullName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Дата" Style="{StaticResource LabelText}"/>
                                <DatePicker x:Name="DpSchedule"/>

                            </StackPanel>

                            <Button Grid.Row="1"
                                    Content="Показати розклад"
                                    Style="{StaticResource SuccessButton}"
                                    Margin="0,12,0,0"
                                Click="BtnScheduleReport_Click"/>
                        </Grid>
                    </Border>

                    <Border x:Name="DogCard"
                            Grid.Row="1" Grid.Column="1"
                            Style="{StaticResource Card}"
                            Margin="12,12,0,0"
                            VerticalAlignment="Stretch">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Text="Звіт по собаці"
                                                   FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="Повний профіль та статистика"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="Собака" Style="{StaticResource LabelText}"/>
                                <ComboBox x:Name="CmbDog" SelectedValuePath="DogId">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Nickname}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                            </StackPanel>

                            <Button Grid.Row="1"
                                    Content="Сформувати звіт"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,12,0,0"
                                    Click="BtnDogReport_Click"/>
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="NoAccessMsg"
                        Style="{StaticResource Card}"
                        Visibility="Collapsed"
                        Margin="0,16,0,0">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="40">
                        <TextBlock Text="🔒" FontSize="48"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Немає доступу до звітів"
                                   FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <TextBlock Text="Зверніться до адміністратора"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>