<Page x:Class="CynologicalCenter.UI.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Звіти">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Звіти"
                   FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,24"/>

        <UniformGrid Grid.Row="1" Columns="2" Rows="2">

            <Border Background="#F8FAFC" CornerRadius="8"
                    Margin="0,0,12,12" Padding="20">
                <StackPanel>
                    <TextBlock Text="📋 Аналіз журналу аудиту"
                               FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="З:" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <DatePicker x:Name="DpAuditFrom" Width="130"/>
                        <TextBlock Text="По:" VerticalAlignment="Center"
                                   Margin="12,0,8,0"/>
                        <DatePicker x:Name="DpAuditTo" Width="130"/>
                    </StackPanel>
                    <Button Content="Сформувати звіт"
                            Height="32" Padding="16,0"
                            Background="#2563EB" Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Click="BtnAuditReport_Click"/>
                </StackPanel>
            </Border>

            <Border Background="#F8FAFC" CornerRadius="8"
                    Margin="0,0,0,12" Padding="20">
                <StackPanel>
                    <TextBlock Text="🔒 Перевірка інцидентів безпеки"
                               FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Аналізувати останні:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="TxtHours" Text="24"
                                 Width="60" Height="32" Padding="8,4"/>
                        <TextBlock Text="годин" VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                    <Button Content="Перевірити"
                            Height="32" Padding="16,0"
                            Background="#DC2626" Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Click="BtnSecurityReport_Click"/>
                </StackPanel>
            </Border>

            <Border Background="#F8FAFC" CornerRadius="8"
                    Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="📅 Розклад тренера"
                               FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Тренер:" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbTrainer" Width="160"
                                  Height="32"
                                  DisplayMemberPath="FullName"
                                  SelectedValuePath="TrainerId"/>
                        <TextBlock Text="Дата:" VerticalAlignment="Center"
                                   Margin="12,0,8,0"/>
                        <DatePicker x:Name="DpSchedule" Width="130"/>
                    </StackPanel>
                    <Button Content="Показати розклад"
                            Height="32" Padding="16,0"
                            Background="#2563EB" Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Click="BtnScheduleReport_Click"/>
                </StackPanel>
            </Border>

            <Border Background="#F8FAFC" CornerRadius="8"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="🐕 Звіт по собаці"
                               FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Собака:" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbDog" Width="160"
                                  Height="32"
                                  DisplayMemberPath="Nickname"
                                  SelectedValuePath="DogId"/>
                    </StackPanel>
                    <Button Content="Сформувати звіт"
                            Height="32" Padding="16,0"
                            Background="#2563EB" Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Click="BtnDogReport_Click"/>
                </StackPanel>
            </Border>

        </UniformGrid>
    </Grid>
</Page>
