<Window x:Class="CynologicalCenter.UI.Dialogs.OwnerEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клієнт" Height="620" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PrimaryBrush}"
                Height="70" Padding="24,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TxtTitle" Text="Новий клієнт"
                           Foreground="White" FontSize="18"
                           FontWeight="Bold"/>
                <TextBlock Text="Заповніть дані клієнта"
                           Foreground="#A8C5BC" FontSize="12"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="ОСОБИСТІ ДАНІ"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextLightBrush}"
                       Margin="0,0,0,10"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="ПІБ *"
                           Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtFullName"
                         Style="{StaticResource ModernTextBox}"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Телефон"
                               Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtPhone"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Email"
                               Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtEmail"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
            </Grid>

            <Border x:Name="DogSection" Grid.Row="3">
                <StackPanel>
                    <Border Height="1"
                            Background="{StaticResource BorderBrush}"
                            Margin="0,0,0,12"/>
                    <TextBlock Text="СОБАКА"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextLightBrush}"
                               Margin="0,0,0,10"/>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Кличка"
                                   Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="TxtDogNickname"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Порода"
                                       Style="{StaticResource LabelText}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CmbBreed" SelectedValuePath="BreedId">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BreedName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="2"
                                        Content="+"
                                        Width="38" Height="38"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="0"
                                        ToolTip="Додати нову породу"
                                        Click="BtnAddBreed_Click"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Дата народження"
                                       Style="{StaticResource LabelText}"/>
                            <DatePicker x:Name="DpDogBirth"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Дата вакцинації"
                                   Style="{StaticResource LabelText}"/>
                        <DatePicker x:Name="DpVaccination"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="ErrorBorder"
                    Grid.Row="4"
                    Background="#FEE2E2" CornerRadius="8"
                    Padding="12,8" Visibility="Collapsed">
                <TextBlock x:Name="TxtError"
                           Foreground="#DC2626" FontSize="13"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="24,16">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Скасувати"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>
                <Button Content="Зберегти"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>