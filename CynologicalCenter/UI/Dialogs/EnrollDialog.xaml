<Window x:Class="CynologicalCenter.UI.Dialogs.EnrollDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запис на заняття" Height="400" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Запис на заняття"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="Собака" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="2" x:Name="CmbDog"
                  Height="32" Margin="0,0,0,10"
                  DisplayMemberPath="Nickname"
                  SelectedValuePath="DogId"/>

        <TextBlock Grid.Row="3" Text="Тренер" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="4" x:Name="CmbTrainer"
                  Height="32" Margin="0,0,0,10"
                  DisplayMemberPath="FullName"
                  SelectedValuePath="TrainerId"/>

        <TextBlock Grid.Row="5" Text="Курс" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="6" x:Name="CmbCourse"
                  Height="32" Margin="0,0,0,10"
                  DisplayMemberPath="CourseName"
                  SelectedValuePath="CourseId"/>

        <Grid Grid.Row="7" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Дата" Margin="0,0,0,4"/>
                <DatePicker x:Name="DpDate" Height="32"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Час (HH:mm)" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtTime" Height="32"
                         Padding="8,4" Text="10:00"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="8" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="TxtError" Foreground="Red"
                       VerticalAlignment="Center" Margin="0,0,12,0"
                       TextWrapping="Wrap" MaxWidth="200"/>
            <Button Content="Скасувати" Height="32" Padding="16,0"
                    Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="Записати" Height="32" Padding="16,0"
                    Background="#2563EB" Foreground="White"
                    BorderThickness="0" Click="BtnEnroll_Click"/>
        </StackPanel>
    </Grid>
</Window>