<Window x:Class="CynologicalCenter.UI.Dialogs.EnrollDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запис на заняття" Height="520" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PrimaryBrush}"
                Height="70" Padding="24,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Запис на заняття"
                           Foreground="White" FontSize="18"
                           FontWeight="Bold"/>
                <TextBlock Text="Оберіть собаку, тренера та курс"
                           Foreground="#A8C5BC" FontSize="12"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Собака *"
                           Style="{StaticResource LabelText}"/>
                <ComboBox x:Name="CmbDog"
                          DisplayMemberPath="Nickname"
                          SelectedValuePath="DogId"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Тренер *"
                           Style="{StaticResource LabelText}"/>
                <ComboBox x:Name="CmbTrainer"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="TrainerId"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="Курс *"
                           Style="{StaticResource LabelText}"/>
                <ComboBox x:Name="CmbCourse"
                          DisplayMemberPath="CourseName"
                          SelectedValuePath="CourseId"/>
            </StackPanel>

            <Grid Grid.Row="3" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Дата *"
                               Style="{StaticResource LabelText}"/>
                    <DatePicker x:Name="DpDate"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Час (HH:mm) *"
                               Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtTime"
                             Style="{StaticResource ModernTextBox}"
                             Text="10:00"/>
                </StackPanel>
            </Grid>

            <Border x:Name="ErrorBorder"
                    Grid.Row="4"
                    Background="#FEE2E2" CornerRadius="8"
                    Padding="12,8" Visibility="Collapsed">
                <TextBlock x:Name="TxtError"
                           Foreground="#DC2626" FontSize="13"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="24,16">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Скасувати"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>
                <Button Content="Записати"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnEnroll_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>