<Window x:Class="CynologicalCenter.UI.Dialogs.TrainerKpiDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPI тренерів" Height="450" Width="650"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Рейтинг тренерів"
                   FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <DataGrid Grid.Row="1" x:Name="GridKpi"
                  AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Місце"
                    Binding="{Binding Rating}" Width="70"/>
                <DataGridTextColumn Header="Тренер"
                    Binding="{Binding TrainerName}" Width="200"/>
                <DataGridTextColumn Header="Виконано занять"
                    Binding="{Binding TotalSessions}" Width="140"/>
                <DataGridTextColumn Header="Середня оцінка"
                    Binding="{Binding AvgGrade}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>