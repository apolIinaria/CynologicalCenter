<Window x:Class="CynologicalCenter.UI.Dialogs.TrainerKpiDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Рейтинг тренерів" Height="500" Width="680"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Рейтинг тренерів"
                       Style="{StaticResource PageTitle}"
                       Margin="0"/>
            <TextBlock Text="На основі середньої оцінки виконаних занять"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}"
                Padding="0">
            <DataGrid x:Name="GridKpi"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Місце"
                        Binding="{Binding Rating}" Width="80"/>
                    <DataGridTextColumn Header="Тренер"
                        Binding="{Binding TrainerName}" Width="220"/>
                    <DataGridTextColumn Header="Виконано занять"
                        Binding="{Binding TotalSessions}" Width="150"/>
                    <DataGridTextColumn Header="Середня оцінка"
                        Binding="{Binding AvgGrade,
                            StringFormat={}{0:N2}}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>