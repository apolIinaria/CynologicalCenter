<Window x:Class="CynologicalCenter.UI.Dialogs.CompleteSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завершити заняття" Height="360" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SuccessBrush}"
                Height="70" Padding="24,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Завершення заняття"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"/>
                <TextBlock x:Name="TxtTitle"
                           Foreground="#A7F3D0"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Оцінка (1–10) *"
                           Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtGrade"
                         Style="{StaticResource ModernTextBox}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Коментар від тренера"
                           Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtComment"
                         Style="{StaticResource ModernTextBoxMulti}"
                         Height="80"/>
            </StackPanel>

            <Border x:Name="ErrorBorder"
                    Grid.Row="2"
                    Background="#FEE2E2"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="0,0,0,12"
                    Visibility="Collapsed">
                <TextBlock x:Name="TxtError"
                           Foreground="#DC2626"
                           FontSize="13"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="16">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Скасувати"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>

                <Button Content="Завершити"
                        Style="{StaticResource SuccessButton}"
                        Click="BtnComplete_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>