<Window x:Class="CynologicalCenter.UI.Dialogs.CompleteSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завершити заняття" Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtTitle"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="Оцінка (1–10) *"
                   Margin="0,0,0,4"/>
        <TextBox Grid.Row="2" x:Name="TxtGrade"
                 Height="32" Padding="8,4" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="Коментар"
                   Margin="0,0,0,4"/>
        <TextBox Grid.Row="4" x:Name="TxtComment"
                 Height="80" Padding="8,4"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Margin="0,0,0,16"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="TxtError" Foreground="Red"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
            <Button Content="Скасувати" Height="32" Padding="16,0"
                    Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="Завершити" Height="32" Padding="16,0"
                    Background="#16A34A" Foreground="White"
                    BorderThickness="0" Click="BtnComplete_Click"/>
        </StackPanel>
    </Grid>
</Window>
