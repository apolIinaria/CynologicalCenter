<Window x:Class="CynologicalCenter.UI.Dialogs.ScheduleReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Розклад тренера" Height="560" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Розклад тренера"
                       Style="{StaticResource PageTitle}"
                       Margin="0"/>
            <TextBlock x:Name="TxtHeader"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}"
                Padding="0">
            <DataGrid x:Name="GridSchedule"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Час"
                        Binding="{Binding [час]}" Width="80"/>
                    <DataGridTextColumn Header="Собака"
                        Binding="{Binding [собака]}" Width="120"/>
                    <DataGridTextColumn Header="Порода"
                        Binding="{Binding [порода]}" Width="140"/>
                    <DataGridTextColumn Header="Власник"
                        Binding="{Binding [власник]}" Width="160"/>
                    <DataGridTextColumn Header="Телефон"
                        Binding="{Binding [телефон]}" Width="130"/>
                    <DataGridTextColumn Header="Курс"
                        Binding="{Binding [курс]}" Width="160"/>
                    <DataGridTextColumn Header="Статус"
                        Binding="{Binding [статус]}" Width="110"/>
                    <DataGridTextColumn Header="Вакцинація"
                        Binding="{Binding [вакцинація]}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>