<Window x:Class="CynologicalCenter.UI.Dialogs.DogProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профіль собаки" Height="680" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded">

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}"
                VerticalAlignment="Top" Height="100" Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="64" Height="64"
                        CornerRadius="32"
                        Background="#2F5E50"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center">
                    <Grid>
                        <TextBlock x:Name="TxtDogEmoji"
                                   Text="🐶" FontSize="40"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <Ellipse x:Name="DogPhotoEllipse"
                                 Width="64" Height="64"
                                 Visibility="Collapsed">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="DogPhotoBrush"
                                            Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="TxtDogName"
                               Foreground="White" FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="TxtDogBreed"
                               Foreground="#A8C5BC" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnUploadPhoto"
                            Content="🖼️"
                            Width="36" Height="36"
                            Background="#2F5E50"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,0,8,0"
                            ToolTip="Завантажити фото"
                            Click="BtnUploadPhoto_Click"
                            Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="18"
                                        Padding="0">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnEdit"
                            Content="Редагувати"
                            Height="36" Padding="14,0"
                            Background="#3A2F2A"
                            Foreground="White"
                            BorderThickness="0"
                            Visibility="Collapsed"
                            Click="BtnEdit_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Margin="0,100,0,0" Padding="24">
            <StackPanel>
                <UniformGrid Columns="3" Margin="0,0,0,16">

                    <Border Style="{StaticResource CardSmall}"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Вік"
                                       Style="{StaticResource LabelText}"/>
                            <TextBlock x:Name="TxtAge"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardSmall}"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Власник"
                                       Style="{StaticResource LabelText}"/>
                            <TextBlock x:Name="TxtOwner"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Cursor="Hand"
                                       MouseLeftButtonUp="TxtOwner_Click"/>
                            <TextBlock x:Name="TxtPhone"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardSmall}">
                        <StackPanel>
                            <TextBlock Text="Вакцинація"
                                       Style="{StaticResource LabelText}"/>
                            <TextBlock x:Name="TxtVaccStatus"
                                       FontSize="15" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtVaccDate"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <Border Style="{StaticResource Card}"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Статистика навчання"
                                   Style="{StaticResource SectionTitle}"/>
                        <UniformGrid Columns="4">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Всього занять"
                                           Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="TxtTotalSessions"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Виконано"
                                           Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="TxtCompletedSessions"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Середня оцінка"
                                           Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="TxtAvgGrade"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource WarningBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Рейтинг"
                                           Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="TxtRating"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="0">
                    <StackPanel>
                        <TextBlock Text="Історія занять"
                                   Style="{StaticResource SectionTitle}"
                                   Margin="20,20,20,12"/>
                        <DataGrid x:Name="GridHistory"
                                  Style="{StaticResource ModernDataGrid}"
                                  MaxHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата"
                                    Binding="{Binding [дата_час]}"
                                    Width="140"/>
                                <DataGridTextColumn Header="Курс"
                                    Binding="{Binding [курс]}"
                                    Width="160"/>
                                <DataGridTextColumn Header="Тренер"
                                    Binding="{Binding [тренер]}"
                                    Width="160"/>
                                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding [status]}"
                                    Width="110"/>
                                <DataGridTextColumn Header="Оцінка"
                                    Binding="{Binding [grade]}"
                                    Width="70"/>
                                <DataGridTextColumn Header="Рейтинг"
                                    Binding="{Binding [рейтинг]}"
                                    Width="100"/>
                                <DataGridTextColumn Header="Коментар"
                                    Binding="{Binding [коментар]}"
                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>