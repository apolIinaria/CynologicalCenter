<Window x:Class="CynologicalCenter.UI.Dialogs.CourseEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Курс" Height="460" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PrimaryBrush}"
                Height="64" Padding="20,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TxtTitle"
                           Text="Новий курс"
                           Foreground="White"
                           FontSize="17"
                           FontWeight="Bold"/>
                <TextBlock Text="Заповніть дані курсу"
                           Foreground="#A8C5BC"
                           FontSize="11"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Назва *"
                           Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtName"
                         Style="{StaticResource ModernTextBox}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="Опис"
                           Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtDescription"
                         Style="{StaticResource ModernTextBoxMulti}"
                         Height="70"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ціна (грн)"
                               Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtPrice"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Мін. вік (міс)"
                               Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtMinAge"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
            </Grid>

            <Border x:Name="ErrorBorder"
                    Grid.Row="3"
                    Background="#FEE2E2"
                    CornerRadius="8"
                    Padding="10,6"
                    Visibility="Collapsed">
                <TextBlock x:Name="TxtError"
                           Foreground="#DC2626"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="14">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Скасувати"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>

                <Button Content="Зберегти"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>