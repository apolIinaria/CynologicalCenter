<Window x:Class="CynologicalCenter.UI.Dialogs.AuditReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Аналіз журналу аудиту"
        Height="680" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Журнал аудиту"
                   Style="{StaticResource PageTitle}"/>

        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Margin="0,0,0,16"
                Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Загальна статистика"
                           Style="{StaticResource SectionTitle}"
                           Margin="0,0,0,8"/>

                <DataGrid x:Name="GridStats"
                          Grid.Row="1"
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="True"
                          Height="80"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2.8*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource Card}"
                    Padding="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="По таблицях"
                               Style="{StaticResource SectionTitle}"
                               Margin="0,0,0,8"/>

                    <DataGrid x:Name="GridByTable"
                              Grid.Row="1"
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="True"/>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Детальний журнал"
                               Style="{StaticResource SectionTitle}"
                               Margin="0,0,0,8"/>

                    <DataGrid x:Name="GridDetail"
                              Grid.Row="1"
                              Style="{StaticResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Час"
                                Binding="{Binding [час]}"
                                Width="150"/>
                            <DataGridTextColumn Header="Операція"
                                Binding="{Binding [операція]}"
                                Width="90"/>
                            <DataGridTextColumn Header="Таблиця"
                                Binding="{Binding [таблиця]}"
                                Width="120"/>
                            <DataGridTextColumn Header="Користувач"
                                Binding="{Binding [користувач]}"
                                Width="160"/>
                            <DataGridTextColumn Header="Опис"
                                Binding="{Binding [опис]}"
                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>