<Window x:Class="CynologicalCenter.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кінологічний центр - Вхід"
        Height="320" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🐾 Кінологічний центр"
                   FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,24"/>

        <TextBlock Grid.Row="1" Text="Логін" Margin="0,0,0,4"/>
        <TextBox Grid.Row="2" x:Name="TxtUsername"
                 Height="32" Padding="8,4"
                 Margin="0,0,0,12"/>

        <TextBlock Grid.Row="3" Text="Пароль" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="4" x:Name="TxtPassword"
                     Height="32" Padding="8,4"
                     Margin="0,0,0,16"/>

        <StackPanel Grid.Row="5">
            <TextBlock x:Name="TxtError" Foreground="Red"
                       TextWrapping="Wrap" Margin="0,0,0,8"
                       Visibility="Collapsed"/>
            <Button Content="Увійти" Height="36"
                    Click="BtnLogin_Click"
                    Background="#2563EB" Foreground="White"
                    FontWeight="SemiBold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>