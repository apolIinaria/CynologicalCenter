<Window x:Class="CynologicalCenter.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="300" Width="400">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Login" FontSize="20" Margin="0,0,0,10"/>
            <TextBlock Text="Username"/>
            <TextBox x:Name="UsernameTextBox" Margin="0,0,0,5" />
            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10"/>
            <Button Content="Sign In" Click="SignIn_Click" Width="100"/>
        </StackPanel>
    </Grid>
</Window>