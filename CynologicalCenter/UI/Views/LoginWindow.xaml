<Window x:Class="CynologicalCenter.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="pack://application:,,,/Assets/logo.ico"
        Title="Кінологічний центр"
        Height="520" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBrush}" Margin="0,0,10,0">
            <Grid>
                <Image Source="pack://application:,,,/Assets/login_dog.png"
                       Stretch="Uniform"
                       Opacity="0.75"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,97,0" Height="378" Width="404" RenderTransformOrigin="0.377,0.519">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="-1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform X="88.068"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>

                <StackPanel VerticalAlignment="Top"
                            HorizontalAlignment="Center"
                            Margin="40,40,40,0">
                    <TextBlock Text="Кінологічний центр NovoDog"
                               Foreground="White"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                    <TextBlock Text="Система управління тренуваннями"
                               Foreground="#A8C5BC"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

            </Grid>
        </Border>

        <Border Grid.Column="1" Padding="40">
            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="Вітаємо!"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Увійдіть до системи"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,32"/>

                <TextBlock Text="Логін"
                           Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtUsername"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="Пароль"
                           Style="{StaticResource LabelText}"/>
                <PasswordBox x:Name="TxtPassword"
                             Margin="0,0,0,16"/>

                <Border x:Name="ErrorBorder"
                        Background="#FEE2E2"
                        CornerRadius="8"
                        Padding="12,8"
                        Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtError"
                               Foreground="#DC2626"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>
                <Button Content="Увійти"
                        Style="{StaticResource PrimaryButton}"
                        Height="44" FontSize="14"
                        Click="BtnLogin_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>